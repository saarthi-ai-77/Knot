{
  "productName": "Knot",
  "version": "0.1.0",
  "identifier": "com.knot.app",
  "build": {
    "frontendDist": "../src/ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd src/ui && npm run dev",
    "beforeBuildCommand": "cd src/ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Knot",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "",
    "targets": "all",
    "externalBin": []
  }
}
